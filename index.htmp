<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1" />
    <meta name="theme-color" content="#020617" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>Evrim Game — Direct Preview</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      html, body, #root { width: 100%; min-height: 100%; margin: 0; background: #020617; color: #fff; }
      body { overflow-x: hidden; overscroll-behavior: none; touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
      #boot-status { font: 14px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; padding: 24px; color: rgba(255,255,255,.78); }
      .boot-card { max-width: 560px; margin: 48px auto; padding: 18px; border: 1px solid rgba(255,255,255,.12); border-radius: 18px; background: rgba(15,23,42,.84); }
      .boot-card code { color: #facc15; }
    </style>
    <script type="importmap">
      {
        "imports": {
          "react": "https://esm.sh/react@19.0.0",
          "react-dom/client": "https://esm.sh/react-dom@19.0.0/client?external=react",
          "lucide-react": "https://esm.sh/lucide-react@0.468.0?external=react"
        }
      }
    </script>
  </head>
  <body>
    <div id="root">
      <div id="boot-status">
        <div class="boot-card">
          <strong>Evrim Game yükleniyor...</strong><br />
          Bu doğrudan açılabilir önizleme sürümü CDN üzerinden React/lucide bağımlılıklarını yükler.
          Boş ekran kalırsa internet bağlantısını veya tarayıcı konsolunu kontrol edin.
        </div>
      </div>
    </div>
    <script type="module" src="./dist/assets/index.js"></script>
  </body>
</html>
